# ─── ZapSign ──────────────────────────────────────────────────────────────────
ZAPSIGN_API_TOKEN=seu_token_aqui

# ─── Zendesk ──────────────────────────────────────────────────────────────────
ZENDESK_SUBDOMAIN=suaempresa
ZENDESK_EMAIL=seu@email.com
ZENDESK_API_TOKEN=seu_token_zendesk

# ─── Segurança ────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=uma_chave_secreta_longa_e_aleatoria

# ─── Alertas de erro (opcional) ───────────────────────────────────────────────
# Crie um Incoming Webhook no Slack e cole a URL aqui
# Deixe em branco para desativar alertas
SLACK_WEBHOOK_URL=

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
