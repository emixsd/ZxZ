# ============================================
# ZapSign
# ============================================
# Token de API — encontre em: Configurações > Integração
ZAPSIGN_API_TOKEN=seu_token_aqui

# URL base da API (use sandbox para testes)
# Produção: https://api.zapsign.com.br/api/v1
# Sandbox:  https://sandbox.api.zapsign.com.br/api/v1
ZAPSIGN_BASE_URL=https://sandbox.api.zapsign.com.br/api/v1

# Token do modelo DOCX (opcional — se não definido, usa PDF_URL)
# Encontre em: https://app.zapsign.com.br/conta/modelos/
ZAPSIGN_TEMPLATE_ID=

# URL pública do PDF (fallback se TEMPLATE_ID não definido)
ZAPSIGN_PDF_URL=

# ============================================
# Zendesk
# ============================================
# Subdomínio (ex: se URL é minhaempresa.zendesk.com, use "minhaempresa")
ZENDESK_SUBDOMAIN=sua-empresa

# E-mail do agente com permissão de API
ZENDESK_EMAIL=agente@empresa.com

# Token de API do Zendesk — encontre em: Admin > Channels > API
ZENDESK_API_TOKEN=seu_token_zendesk

# ============================================
# Servidor
# ============================================
PORT=3000

# Chave para validar webhooks recebidos do Zendesk
WEBHOOK_SECRET=gere_uma_chave_segura_aqui
